ax_bar.set_yscale('log')
ax_bar.set_title("Zero-Shot Resolution Generalization Test (Evaluated at 64x64 Grid)", fontweight='bold', fontsize=11)
ax_bar.set_xticks(x_positions)
ax_bar.set_xticklabels([pde.upper() for pde in active_pdes], fontweight='bold')
ax_bar.set_ylabel("Log Testing MSE Loss")
ax_bar.grid(True, which="both", linestyle=":", alpha=0.5)
